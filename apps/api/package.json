{
  "name": "@werewolf/api",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=../../.env --env-file-if-exists=./.env src/server.ts",
    "start": "PORT=12003 node --env-file-if-exists=./.env dist/server.bundle.js",
    "start:legacy": "node --env-file-if-exists=../../.env --env-file-if-exists=./.env dist/server.js",
    "build": "tsc -p tsconfig.json",
    "build:bundle": "bun build ./src/server.ts --target=node --outfile=dist/server.bundle.js --external '@livekit/rtc-node' --external '@livekit/rtc-node-darwin-arm64' --external '@livekit/rtc-node-darwin-x64' --external '@livekit/rtc-node-linux-x64-gnu' --external 'mpg123-decoder'",
    "pack": "bun run build:bundle && node scripts/pack.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.0",
    "@livekit/rtc-node": "^0.13.24",
    "@types/ws": "^8.18.1",
    "@werewolf/agent-client": "workspace:*",
    "@werewolf/db": "workspace:*",
    "@werewolf/engine": "workspace:*",
    "@werewolf/shared": "workspace:*",
    "drizzle-orm": "^0.45.0",
    "hono": "^4.10.0",
    "livekit-server-sdk": "^2.15.2",
    "mpg123-decoder": "^1.0.3",
    "ws": "^8.20.0",
    "zod": "^4.1.0"
  },
  "devDependencies": {
    "tsx": "^4.21.0",
    "typescript": "^5.9.0",
    "vitest": "^4.0.0"
  },
  "optionalDependencies": {
    "@livekit/rtc-node-darwin-arm64": "0.13.24",
    "@livekit/rtc-node-darwin-x64": "0.13.24",
    "@livekit/rtc-node-linux-x64-gnu": "0.13.24"
  }
}
